    "definitions": {
        "httperrors.ErrorResponse": {
            "type": "object",
            "properties": {
                "details": {
                    "type": "object",
                    "additionalProperties": {
                        "type": "string"
                    }
                },
                "error": {
                    "type": "string"
                },
                "message": {
                    "type": "string"
                },
                "status": {
                    "type": "integer"
                }
            }
        },
        "repository.Chat": {
            "type": "object",
            "properties": {
                "avatar_url": {
                    "type": "string"
                },
                "created_at": {
                    "type": "string"
                },
                "deleted_at": {
                    "type": "string"
                },
                "id": {
                    "type": "string"
                },
                "metadata": {
                    "type": "array",
                    "items": {
                        "type": "integer"
                    }
                },
                "title": {
                    "type": "string"
                },
                "type": {
                    "$ref": "#/definitions/repository.ChatType"
                },
                "updated_at": {
                    "type": "string"
                }
            }
        },
        "repository.ChatType": {
            "type": "string",
            "enum": [
                "private",
                "group",
                "channel"
            ],
            "x-enum-varnames": [
                "ChatTypePrivate",
                "ChatTypeGroup",
                "ChatTypeChannel"
            ]
        },
        "repository.Message": {
            "type": "object",
            "properties": {
                "chat_id": {
                    "type": "string"
                },
                "content": {
                    "type": "string"
                },
                "created_at": {
                    "type": "string"
                },
                "deleted_at": {
                    "type": "string"
                },
                "id": {
                    "type": "string"
                },
                "reply_message_id": {
                    "type": "string"
                },
                "sender_id": {
                    "type": "string"
                },
                "topic_id": {
                    "type": "string"
                },
                "updated_at": {
                    "type": "string"
                }
            }
        },
        "repository.Topic": {
            "type": "object",
            "properties": {
                "avatar_url": {
                    "type": "string"
                },
                "chat_id": {
                    "type": "string"
                },
                "creted_at": {
                    "type": "string"
                },
                "deleted_at": {
                    "type": "string"
                },
                "id": {
                    "type": "string"
                },
                "title": {
                    "type": "string"
                },
                "type": {
                    "$ref": "#/definitions/repository.TopicType"
                },
                "updated_at": {
                    "type": "string"
                }
            }
        },
        "repository.TopicType": {
            "type": "string",
            "enum": [
                "text_topic",
                "voice_topic"
            ],
            "x-enum-varnames": [
                "TopicTypeTextTopic",
                "TopicTypeVoiceTopic"
            ]
        },
        "services.AccessToken": {
            "type": "object",
            "properties": {
                "token": {
                    "type": "string"
                }
            }
        },
        "services.CreateChatDTO": {
            "type": "object",
            "properties": {
                "title": {
                    "type": "string",
                    "example": "General Chat"
                },
                "type": {
                    "type": "string",
                    "enum": [
                        "private",
                        "group",
                        "channel"
                    ],
                    "example": "group"
                }
            }
        },
        "services.LoginUserDTO": {
            "type": "object",
            "properties": {
                "password": {
                    "type": "string"
                },
                "username": {
                    "type": "string"
                }
            }
        },
        "services.RegisterUserDTO": {
            "type": "object",
            "properties": {
                "password": {
                    "type": "string"
                },
                "username": {
                    "type": "string"
                }
            }
        }
